{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["ES2022", "DOM"],
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@yanak/types": ["packages/types/src"],
      "@yanak/pricing": ["packages/pricing/src"],
      "@yanak/pricing/*": ["packages/pricing/src/*"],
      "@yanak/ui": ["packages/ui/src"],
      "@yanak/receipt": ["packages/receipt/src"],
      "@yanak/constructor": ["packages/constructor/src"]
    }
  }
}
