DATABASE_URL="postgresql://yanak:yanak@localhost:5432/yanak?schema=public"

# Nest API — для backoffice (прокси) и web (rewrites)
# Локально: http://localhost:4000
# Docker:   http://api:4000
# Продакшен: https://api.example.com
BACKEND_API_URL=http://localhost:4000

# Витрина (apps/web): прямой URL Nest из браузера для каталога — обходит неверный прокси Next.
# В CORS_ORIGINS на API добавьте домен витрины. Пример: NEXT_PUBLIC_API_BASE_URL=https://api.example.com
# NEXT_PUBLIC_API_BASE_URL=

# Web: при сборке из админки — URL API (API_URL переопределяет BACKEND_API_URL)
# API_URL=https://api.example.com npm run build -w apps/web

# Превью само берёт /baget-assets/{sku}.jpg из public после catalog:download-images

# API CORS: продакшен-домены витрины, админки и т.д. (через запятую). Локальные порты уже разрешены в коде.
# Добавьте и www, если открываете витрину по www (как в deploy/Caddyfile).
# CORS_ORIGINS=https://shop.example.com,https://www.shop.example.com,https://admin.example.com
#
# Сессия админки по HTTPS: в Docker передайте COOKIE_SECURE=1 (см. docker-compose.yml → api).
# COOKIE_SECURE=1

# Манифест обновлений десктопной админки (Electron) — отдаётся с GET /api/system/desktop-admin-update
# DESKTOP_ADMIN_LATEST_VERSION=1.0.1
# DESKTOP_ADMIN_DOWNLOAD_URL=https://releases.example.com/Yanak.Admin.Setup.1.0.1.exe
# DESKTOP_ADMIN_RELEASE_NOTES=Исправления безопасности
# DESKTOP_ADMIN_MIN_VERSION=1.0.0

# Визуальный заказ в админке встроен в страницу (без iframe). Если сами встраиваете /embed с витрины в HTTPS-страницу — см. ?yanakParentHttps=1 в URL и TLS на витрине.
# NEXT_PUBLIC_IFRAME_PARENT_IS_HTTPS=1

# ngrok: NGROK_AUTHTOKEN с https://dashboard.ngrok.com/get-started/your-authtoken
# Запуск: npm run ngrok:up   |   показать HTTPS-ссылки: npm run ngrok:urls   |   инспектор http://localhost:4040
# NGROK_AUTHTOKEN=your_token_here

# Календарные сутки (00:00–00:00) для дашборда и отчёта по продажам. IANA, например Europe/Chisinau, Europe/Moscow.
# В Docker передайте и NEXT_PUBLIC_ (для клиентских страниц админки): см. docker-compose.yml → backoffice.
# BUSINESS_TIMEZONE=Europe/Chisinau

# Docker: витрина (web). 0 = next build + start (быстрее). 1 = next dev + HMR.
NEXT_DEV_FRONTEND=0
# Docker: админка (backoffice). 0 = build + start (быстрее). 1 = next dev + HMR.
NEXT_DEV_BACKOFFICE=0

# Docker: backoffice — пропустить next build при старте, если уже есть готовая сборка (только при NEXT_DEV_BACKOFFICE=0)
# SKIP_BACKOFFICE_NEXT_BUILD=1

# Docker API: при старте контейнера запускать db:seed + auth:seed (каталог из JSON, материалы, стекло/задник, магазины по умолчанию, учётки).
# По умолчанию в compose = 0 — данные в БД не перезаписываются при каждом restart. Первый раз или после сброса тома postgres:
#   docker compose run --rm -e RUN_SEED_ON_START=1 api sh -c "npm install && npm run db:seed && npm run auth:seed"
# или в .env: RUN_SEED_ON_START=1 (только для первого подъёма)
# RUN_SEED_ON_START=0

# Если всё же запускаете auth:seed и нужно принудительно выставить пароли из скрипта:
# AUTH_SEED_FORCE_PASSWORD=1

# --- Локально ---
# Docker (весь стек без прод-URL в витрине): npm run compose:local  (docker-compose.local.yml)
# npm run dev подмешивает config/env.local-dev.env поверх .env — витрина не ходит на NEXT_PUBLIC_API_BASE_URL из продакшена.
# Только Postgres+Redis в Docker: docker compose up -d postgres redis → в .env порт 5433: DATABASE_URL=...@localhost:5433/...
#
# --- Деплой на сервер (Linux + Docker) ---
# Полный чеклист: deploy/SERVER.md
# Бэкап БД + baget-assets: scripts/server-backup.sh | восстановление: scripts/server-restore.sh
#
# В docker-compose на проде задайте сильный пароль Postgres и ту же строку в DATABASE_URL для api (через переменные или правку compose).
# Публичные URL для сборки фронтов и CORS:
# CORS_ORIGINS=https://shop.example.com,https://admin.example.com
# API_URL=https://api.example.com
# NEXT_PUBLIC_API_BASE_URL=https://api.example.com
# BACKEND_API_URL=https://api.example.com   # для прокси backoffice, если собираете вне Docker
#
# HTTPS на сервере (Caddy в Docker): npm run compose:https
# deploy/Caddyfile — домены и прокси на web:3000, api:4000, backoffice:3001
# CADDY_EMAIL=you@example.com
#
# Обход блокировки входящих 80/443: Cloudflare Zero Trust -> Tunnels -> токен в .env
# CLOUDFLARE_TUNNEL_TOKEN=

# DNS в Cloudflare (A-записи на IP сервера): npm run dns:cf-sync
# Токен: My Profile → API Tokens → создать с правом Zone → DNS → Edit для зоны.
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ZONE_NAME=bagetnaya-yanak.ru
# TARGET_IPV4=203.0.113.10
# или TARGET_IPV4=auto — подставит текущий публичный IP машины, с которой запущен скрипт
# DNS_A_RECORDS=bagetnaya-yanak.ru,www.bagetnaya-yanak.ru,api.bagetnaya-yanak.ru,admin.bagetnaya-yanak.ru
# CLOUDFLARE_DNS_PROXIED=1
