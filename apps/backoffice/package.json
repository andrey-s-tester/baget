{
  "name": "@yanak/backoffice",
  "version": "0.2.4",
  "private": true,
  "scripts": {
    "dev": "env-cmd -f ../../.env -f ../../config/env.local-dev.env -- next dev --turbopack -H 0.0.0.0 -p 3001",
    "dev:domain": "env-cmd -f ../../.env -- next dev --turbopack -H 0.0.0.0 -p 3001",
    "dev:fresh": "node -e \"try{require('fs').rmSync('.next',{recursive:true,force:true})}catch(e){}\" && env-cmd -f ../../.env -f ../../config/env.local-dev.env -- next dev --turbopack -H 0.0.0.0 -p 3001",
    "dev:webpack": "env-cmd -f ../../.env -f ../../config/env.local-dev.env -- next dev -H 0.0.0.0 -p 3001",
    "dev:turbo": "env-cmd -f ../../.env -f ../../config/env.local-dev.env -- next dev --turbopack -H 0.0.0.0 -p 3001",
    "dev:prod": "next build && next start -p 3001",
    "build": "next build",
    "start": "next start -H 0.0.0.0 -p 3001",
    "lint": "next lint",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@yanak/constructor": "0.1.0",
    "@yanak/receipt": "0.1.0",
    "@yanak/pricing": "0.1.0",
    "@yanak/types": "0.1.0",
    "@yanak/ui": "0.1.0",
    "next": "^15.5.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hot-toast": "^2.6.0"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "typescript": "^5.9.2"
  }
}
